{
  "manifest_version": 3,
  "name": "CPA Codex OAuth Auto Login",
  "version": "0.1.6",
  "description": "Assists a selected local CPA Codex account through the OpenAI OAuth login flow.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "webNavigation",
    "storage",
    "sidePanel",
    "cookies",
    "browsingData",
    "debugger"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://auth.openai.com/*",
    "https://auth0.openai.com/*",
    "https://accounts.openai.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://platform.openai.com/*",
    "https://openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CPA Codex OAuth"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "content-cpa.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://auth.openai.com/*",
        "https://auth0.openai.com/*",
        "https://accounts.openai.com/*"
      ],
      "js": [
        "content-openai.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
