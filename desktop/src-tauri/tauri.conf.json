{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Quota Desk",
  "version": "0.1.1",
  "identifier": "com.cpa.quota.desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Quota Desk",
        "width": 1480,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
